# AI Content Engine — environment template
# Copy to .env and fill with real values. .env is gitignored — NEVER commit real keys.
# In n8n, these live as Credentials; .env is the local source of truth / reference.

# ── Supabase (reuse the project from ai-lead-qualification-system) ─────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE=<service_role key — n8n writes only, NEVER in frontend>
SUPABASE_ANON_KEY=<anon key — safe for the read-only dashboard>

# ── Groq (LLM for content generation) ─────────────────────────────────────────
# Model: llama-3.3-70b-versatile. n8n Header Auth cred value must be "Bearer gsk_..."
GROQ_API_KEY=gsk_...

# ── Telegram (reuse @myleadqualbot) ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<bot token>
TELEGRAM_CHAT_ID=<your chat id>

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_BASE=https://<your-workspace>.app.n8n.cloud

# ── Content source ────────────────────────────────────────────────────────────
# One or more AI/automation news RSS feeds (comma-separated if multiple).
RSS_FEED_URL=https://<ai-automation-news-feed>/rss
